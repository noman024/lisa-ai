# === Recommended for submission / local GPU: vLLM + self-hosted model ===
# 1) Start vLLM (separate process), then 2) LISA API (uvicorn on :8000). See README.
VLLM_BASE_URL=http://127.0.0.1:8001/v1
# Qwen2.5-3B works well on Apple Silicon (M1/M2/M3) with vllm-metal (~2 GB)
VLLM_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
VLLM_API_KEY=not-needed
# Optional: more deterministic sampling when the server supports ``seed`` (omit to leave default)
# LLM_SEED=42
# Chat generation (OpenAI-compatible API — vLLM, etc.)
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=600
LLM_TEMPERATURE=0.1

# --- Optional: OpenAI API instead of vLLM (uncomment and fill) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Generic names: LLM_BASE_URL, LLM_MODEL, LLM_API_KEY (same as above).

# BGE for embeddings (local)
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5

RETRIEVAL_MIN_SCORE=0.32
GROUNDING_MIN_OVERLAP=0.25
RETRIEVER_TOP_K=5
MEMORY_MAX_MESSAGES=20
# Max characters of prior conversation text in the LLM user prompt (long tail is kept)
MEMORY_PROMPT_MAX_CHARS=4000
